# JWT Configuration
# Gunakan secret key yang kuat untuk production
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Dummy User (untuk testing)
DUMMY_USERNAME=admin
DUMMY_PASSWORD=password

# File Paths (default, tidak perlu diubah)
CSV_FILE_PATH=data/sales_data.csv
MODEL_FILE_PATH=ml/model.pkl

# Environment
ENVIRONMENT=development
DEBUG=True

# Frontend Configuration (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8000/api
NEXT_PUBLIC_APP_NAME="Sales Prediction System"